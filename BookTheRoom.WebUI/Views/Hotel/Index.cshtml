@using BookTheRoom.Infrastructure.Identity
@using BookTheRoom.Domain.Entities
@using BookTheRoom.Domain.Enums
@model IEnumerable<Hotel>


<div class="album py-5 bg-body-tertiary">
    <div class="container">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card shadow-sm">
                        <div class="image-container">
                            <img class="card-img-top" src="@item.PreviewImage.URL" alt="Card image cap">
                        </div>
                        <div class="card-body">
                            <p class="card-text">@item.Name</p>
                            <p class="card-text">@item.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="btn-group">
                                    <a type="btn btn-success" asp-controller="Hotel" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a>                                  
                                    @*@if (User.Identity.IsAuthenticated && User.IsInRole(UserRole.Admin))
                                    {*@
                                        <a type="btn btn-success" asp-controller="Hotel" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                        <a type="btn btn-success" asp-controller="Hotel" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Delete</a>
                                    @*}*@

                                </div>
                                <small class="text-body-secondary">Class @item.Rating ★</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>