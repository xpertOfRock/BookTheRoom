@using BookTheRoom.Domain.Entities
@model Room

<div class="container">

    <h1 class="my-4">
        Apartments @Model.Number
    </h1>

    <div class="row">
        <div class="col-md-8">
            <img class="img-fluid" src="@Model.PreviewURL" alt="">
        </div>       

    </div>

    <h3 class="my-4">More Images</h3>

    <div class="row">

        @foreach (var item in Model.ImagesURL)
        {
            <div class="col-md-3 col-sm-6 mb-4">
                <a href="#">
                    <img class="img-fluid" src="@item" width="500" height="300" alt="">
                </a>
            </div>
        }
    </div>
</div>